# UA Designs PMS Environment Configuration
# Copy this file to .env and update with your actual values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=development
PORT=5000
HOST=localhost

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL (Production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ua_designs_pms
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DIALECT=postgresql

# SQLite (Development only - uncomment to use)
# DB_STORAGE=./database.sqlite
# DB_DIALECT=sqlite

# ===========================================
# JWT CONFIGURATION
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@uadesigns.com
EMAIL_SECURE=false

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# ===========================================
# AWS CONFIGURATION (File Storage)
# ===========================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ua-designs-uploads

# ===========================================
# PUSHER CONFIGURATION (Real-time Features)
# ===========================================
PUSHER_APP_ID=your-pusher-app-id
PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=us2

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-key-change-this-in-production

# ===========================================
# EXTERNAL APIs
# ===========================================
WEATHER_API_KEY=your-weather-api-key
MAPS_API_KEY=your-google-maps-api-key

# ===========================================
# DEVELOPMENT TOOLS
# ===========================================
DEBUG=ua-designs:*
NODEMON_IGNORE=node_modules,logs,uploads

# ===========================================
# PMBOK CONFIGURATION
# ===========================================
PMBOK_VERSION=7
CONSTRUCTION_INDUSTRY_SPECIFIC=true

# ===========================================
# UA DESIGNS COMPANY CONFIGURATION
# ===========================================
COMPANY_NAME=UA Designs
COMPANY_EMAIL=info@uadesigns.com
COMPANY_PHONE=+1234567890
COMPANY_ADDRESS=Your Company Address
COMPANY_WEBSITE=https://uadesigns.com

# ===========================================
# DEFAULT ADMIN USER (First Run Only)
# ===========================================
ADMIN_EMAIL=admin@uadesigns.com
ADMIN_PASSWORD=admin123
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# ===========================================
# DEVELOPMENT FEATURES
# ===========================================
ENABLE_SWAGGER=true
ENABLE_LOGGING=true
ENABLE_DEBUG_ROUTES=false

# ===========================================
# PRODUCTION SETTINGS (Override for production)
# ===========================================
# NODE_ENV=production
# LOG_LEVEL=warn
# DEBUG=
# ENABLE_SWAGGER=false
# ENABLE_DEBUG_ROUTES=false